<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在初始化..."
            android:textSize="16sp"
            android:textAlignment="center"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="16dp"
            android:textStyle="bold" />

        <!-- 设置区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ 设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="蓝牙设备名称："
                android:textSize="14sp" />

            <EditText
                android:id="@+id/deviceNameEditText"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="SYNC"
                android:textSize="14sp"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="热点关闭延迟（秒）："
                android:textSize="14sp" />

            <EditText
                android:id="@+id/closeDelayEditText"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="60"
                android:textSize="14sp"
                android:inputType="number"
                android:maxLines="1" />
        </LinearLayout>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 保存设置"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- 服务控制区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 服务控制"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/startServiceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶️ 启动后台监控服务"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/stopServiceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹️ 停止服务"
            android:textSize="16sp"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="16dp" />

        <!-- 设备信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 设备信息"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/deviceInfoTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="12sp"
            android:textColor="#666666"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- 日志区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 调试日志"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:fillViewport="true"
            android:scrollbars="vertical|horizontal">

            <TextView
                android:id="@+id/logTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="等待日志..."
                android:textSize="11sp"
                android:textColor="#333333"
                android:fontFamily="monospace"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:scrollbars="vertical"
                android:lineSpacingExtra="4dp" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/clearLogButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ 清空日志"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#757575" />

        <!-- 说明区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 使用说明：\n\n1. 修改设备名称和延迟时间\n2. 点击'保存设置'\n3. 点击'启动后台监控服务'\n4. 通知栏会显示监控状态\n5. 连接到指定设备时自动开启热点\n\n⚠️ HarmonyOS 用户首次需手动开启一次热点"
            android:textSize="13sp"
            android:textAlignment="center"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#666666"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
